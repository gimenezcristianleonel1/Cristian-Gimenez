# Base de datos (Supabase Postgres). Para desarrollo local con docker-compose
# se usa el valor por defecto que apunta al contenedor "db".
DATABASE_URL=postgresql+psycopg2://postgres:postgres@db:5432/nexo_prestamos

# JWT
JWT_SECRET_KEY=change-this-secret-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# CORS: orígenes permitidos separados por coma
CORS_ORIGINS=http://localhost:5173

# Entorno: local | production
ENVIRONMENT=local
